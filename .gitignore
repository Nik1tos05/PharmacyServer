# Build artifacts
bin/
obj/
*.exe
*.dll
*.pdb
*.userprefs
*.cache
*.compiled
*.log
*.tmp
*.swp
*.swo

# Dependencies
packages/
node_modules/
.nuget/
.npm/
.yarn/

# Environment
.env
.env.local
.env.*
!.env.example

# Editors
.vscode/
.idea/
*.user
*.userosscache
*.sln.docstates

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test results
TestResults/
coverage/
*.coverage
```