<UserControl x:Class="PharmacyClient.Views.QueriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель выбора запроса -->
        <Border Grid.Row="0" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1" 
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,10"
                Background="#E8F5E9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Выберите запрос:" 
                           FontWeight="Bold"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding AvailableQueries}"
                          SelectedItem="{Binding SelectedQuery}"
                          DisplayMemberPath="DisplayName"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        Content="Выполнить" 
                        Command="{Binding ExecuteQueryCommand}"
                        Padding="20,8"
                        Background="#4CAF50"
                        Foreground="White"
                        IsEnabled="{Binding SelectedQuery, Converter={StaticResource NullToBoolConverter}}"/>
            </Grid>
        </Border>

        <!-- Параметры запроса -->
        <Border Grid.Row="1" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1" 
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,10"
                Visibility="{Binding ShowParameters, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="#FFF3E0">
            <StackPanel>
                <TextBlock Text="Параметры запроса:" 
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,10"/>
                
                <!-- Параметры для разных запросов -->
                <Grid Visibility="{Binding ShowCategoryParameter, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Категория медикаментов:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" 
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              DisplayMemberPath="CategoryName"
                              Margin="5,0,0,0"/>
                </Grid>

                <Grid Visibility="{Binding ShowDateRangeParameter, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,5,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Период:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="С:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <DatePicker Grid.Column="2" SelectedDate="{Binding StartDate}" Margin="5,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="По:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <DatePicker Grid.Column="4" SelectedDate="{Binding EndDate}" Margin="5,0,0,0"/>
                </Grid>

                <Grid Visibility="{Binding ShowMedicineParameter, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,5,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Лекарство:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" 
                              ItemsSource="{Binding Medicines}"
                              SelectedItem="{Binding SelectedMedicine}"
                              DisplayMemberPath="MedicineName"
                              Margin="5,0,0,0"/>
                </Grid>

                <!-- Этот блок больше не нужен, так как для запросов 11 и 13 используется DataGrid в окне результатов -->

                <Grid Visibility="{Binding ShowMedicineTypeParameter, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,5,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Тип лекарства:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" 
                              ItemsSource="{Binding MedicineTypes}"
                              SelectedItem="{Binding SelectedMedicineType}"
                              DisplayMemberPath="TypeName"
                              Margin="5,0,0,0"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
                    <Button Content="Применить параметры" 
                            Command="{Binding ApplyParametersCommand}"
                            Padding="15,8"
                            Background="#2196F3"
                            Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Результаты запроса -->
        <Border Grid.Row="1"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="5"
                Margin="0,0,0,10">
            <Grid>
                <!-- DataGrid для результатов запроса -->
                <DataGrid x:Name="ResultsGrid"
                          ItemsSource="{Binding QueryResults}"
                          AutoGenerateColumns="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="All"
                          AlternatingRowBackground="#F5F5F5"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          ColumnWidth="SizeToCells"
                          Visibility="{Binding ShowMedicineListForQuery, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>

                <!-- Список лекарств для выбора (для запросов 11 и 13) -->
                <DataGrid x:Name="MedicineSelectionGrid"
                          ItemsSource="{Binding Medicines}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          GridLinesVisibility="All"
                          AlternatingRowBackground="#F5F5F5"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          ColumnWidth="SizeToCells"
                          Visibility="{Binding ShowMedicineListForQuery, Converter={StaticResource BoolToVisibilityConverter}}"
                          SelectedItem="{Binding SelectedMedicine, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding MedicineId}" Width="50"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding MedicineName}" Width="200"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category.CategoryName}" Width="150"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding MedicineType.TypeName}" Width="150"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding SalePrice, StringFormat=F2}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Индикатор загрузки -->
                <Border Background="#80FFFFFF"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                        <TextBlock Text="Выполнение запроса..." 
                                   HorizontalAlignment="Center"
                                   FontSize="14"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Статусная панель -->
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Orientation="Horizontal">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontWeight="Bold"
                       Foreground="#333"/>
            <TextBlock Text="{Binding ResultCount, StringFormat='Всего записей: {0}'}" 
                       FontWeight="Bold"
                       Margin="20,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
