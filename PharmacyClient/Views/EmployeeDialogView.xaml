<Window x:Class="PharmacyClient.Views.EmployeeDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding IsEditMode, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Редактирование сотрудника|Добавление сотрудника'}"
        Height="650" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма ввода данных -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Основные данные" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                <!-- Фамилия -->
                <TextBlock Grid.Row="1" Text="Фамилия *" Margin="0,0,0,5"/>
                <TextBox Grid.Row="2" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                         Margin="0,0,0,15" Padding="8"/>

                <!-- Имя -->
                <TextBlock Grid.Row="3" Text="Имя *" Margin="0,0,0,5"/>
                <TextBox Grid.Row="4" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                         Margin="0,0,0,15" Padding="8"/>

                <!-- Отчество -->
                <TextBlock Grid.Row="5" Text="Отчество" Margin="0,0,0,5"/>
                <TextBox Grid.Row="6" Text="{Binding Patronymic, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,15" Padding="8"/>

                <!-- Должность -->
                <TextBlock Grid.Row="7" Text="Должность *" Margin="0,0,0,5"/>
                <TextBox Grid.Row="8" Text="{Binding Position, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                         Margin="0,0,0,15" Padding="8"/>

                <!-- Отдел -->
                <TextBlock Grid.Row="9" Text="Отдел" Margin="0,0,0,5"/>
                <ComboBox Grid.Row="10" ItemsSource="{Binding Departments}" 
                          SelectedItem="{Binding Department}" 
                          Margin="0,0,0,15" Padding="8"/>

                <!-- Дата приема -->
                <TextBlock Grid.Row="11" Text="Дата приема" Margin="0,0,0,5"/>
                <DatePicker Grid.Row="12" SelectedDate="{Binding HireDate, Converter={StaticResource DateOnlyToDateTimeConverter}}" 
                            Margin="0,0,0,15" Padding="8"/>

                <!-- Телефон -->
                <TextBlock Grid.Row="13" Text="Телефон" Margin="0,0,0,5"/>
                <TextBox Grid.Row="14" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,15" Padding="8"/>

                <!-- Email -->
                <TextBlock Grid.Row="15" Text="Email" Margin="0,0,0,5"/>
                <TextBox Grid.Row="16" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,15" Padding="8"/>

                <TextBlock Grid.Row="17" Text="Дополнительно" FontWeight="Bold" FontSize="14" Margin="0,10,0,10"/>

                <!-- Паспорт -->
                <Grid Grid.Row="18" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Серия паспорта" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding PassportSeries, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Номер паспорта" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding PassportNumber, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                    </StackPanel>
                </Grid>

                <!-- Оклад -->
                <TextBlock Grid.Row="19" Text="Оклад (₽)" Margin="0,0,0,5"/>
                <TextBox Grid.Row="20" Text="{Binding Salary, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                         Margin="0,0,0,15" Padding="8"/>

                <!-- Чекбоксы -->
                <StackPanel Grid.Row="21" Orientation="Vertical" Margin="0,0,0,15">
                    <CheckBox Content="Менеджер" IsChecked="{Binding IsManager}" Margin="0,5"/>
                    <CheckBox Content="Может подписывать документы" IsChecked="{Binding CanSignDocuments}" Margin="0,5"/>
                    <CheckBox Content="Активен" IsChecked="{Binding IsActive}" Margin="0,5"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                    Padding="20,10" Margin="0,0,10,0" MinWidth="100"
                    Background="#4CAF50" Foreground="White"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" 
                    Padding="20,10" MinWidth="100"
                    Background="#f44336" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
