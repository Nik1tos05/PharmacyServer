<UserControl x:Class="PharmacyClient.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PharmacyClient.ViewModels"
             Margin="10">
    <UserControl.DataContext>
        <vm:OrdersViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="200" Margin="0,0,10,0"/>
            
            <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding StatusOptions}" 
                      SelectedItem="{Binding StatusFilter}" 
                      Width="150" Margin="0,0,10,0"/>
            
            <Button Content="Загрузить" Command="{Binding LoadOrdersCommand}" 
                    Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Добавить" Command="{Binding AddOrderCommand}" 
                    Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Удалить" Command="{Binding DeleteOrderCommand}" 
                    Padding="10,5"/>
        </StackPanel>

        <!-- Orders List -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Orders}" 
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                  BeginningEdit="OrdersGrid_BeginningEdit"
                  RowEditEnding="OrdersGrid_RowEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ заказа" Binding="{Binding OrderNumber}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Рецепт" Binding="{Binding Prescription.PrescriptionNumber, TargetNullValue=''}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Пациент" Binding="{Binding Patient.LastName}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding TotalPrice, StringFormat={}{0:C}}" Width="80" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Статус" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.StatusOptions}"
                                      SelectedItem="{Binding OrderStatus, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Готовность" Binding="{Binding ReadyDate, StringFormat={}{0:dd.MM.yyyy}, TargetNullValue=''}" Width="90"/>
                <DataGridTextColumn Header="Выдан" Binding="{Binding PickupDate, StringFormat={}{0:dd.MM.yyyy}, TargetNullValue=''}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontWeight="Bold"/>
            <TextBlock Text=" | " Margin="5,0"/>
            <TextBlock>
                <Run Text="Всего заказов: "/>
                <Run Text="{Binding TotalCount}"/>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
