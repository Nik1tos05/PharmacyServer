<UserControl x:Class="PharmacyClient.Views.TechnologiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PharmacyClient.ViewModels"
             Margin="10">
    <UserControl.DataContext>
        <vm:TechnologiesViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="200" Margin="0,0,10,0"/>
            
            <TextBlock Text="Тип лекарства:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding MedicineTypeOptions}" 
                      SelectedItem="{Binding MedicineTypeFilter}" 
                      Width="150" Margin="0,0,10,0"/>
            
            <Button Content="Загрузить" Command="{Binding LoadTechnologiesCommand}" 
                    Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Добавить" Command="{Binding AddTechnologyCommand}" 
                    Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Редактировать" Command="{Binding EditTechnologyCommand}" 
                    Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Удалить" Command="{Binding DeleteTechnologyCommand}" 
                    Padding="10,5"/>
        </StackPanel>

        <!-- Technologies List -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Technologies}" 
                  SelectedItem="{Binding SelectedTechnology}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код технологии" Binding="{Binding TechnologyCode}" Width="120"/>
                <DataGridTextColumn Header="Название лекарства" Binding="{Binding MedicineName}" Width="180"/>
                <DataGridTextColumn Header="Тип лекарства" Binding="{Binding MedicineType.TypeName}" Width="130"/>
                <DataGridTextColumn Header="Метод приготовления" Binding="{Binding PreparationMethod}" Width="250"/>
                <DataGridTextColumn Header="Время (мин)" Binding="{Binding PreparationTimeMinutes}" Width="90"/>
                <DataGridTextColumn Header="Активна" Binding="{Binding IsActive}" Width="70"/>
                <DataGridTextColumn Header="Создана" Binding="{Binding CreatedDate, StringFormat={}{0:dd.MM.yyyy}, TargetNullValue=''}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontWeight="Bold"/>
            <TextBlock Text=" | " Margin="5,0"/>
            <TextBlock>
                <Run Text="Всего технологий: "/>
                <Run Text="{Binding TotalCount}"/>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
