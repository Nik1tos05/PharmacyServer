<UserControl x:Class="PharmacyClient.Views.MedicinesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопки управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Управление лекарствами" 
                       FontSize="20" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0"/>
            
            <Button Content="Добавить" 
                    Command="{Binding AddMedicineCommand}"
                    Padding="15,8"
                    Margin="5,0"
                    Background="#4CAF50"
                    Foreground="White"/>
            
            <Button Content="Удалить" 
                    Command="{Binding DeleteMedicineCommand}"
                    Padding="15,8"
                    Margin="5,0"
                    Background="#f44336"
                    Foreground="White"/>
            
            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}"
                    Padding="15,8"
                    Margin="5,0"/>
        </StackPanel>

        <!-- Панель поиска и фильтров -->
        <Border Grid.Row="1" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1" 
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0"
                             x:Name="SearchTextBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8"
                             Margin="0,0,5,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    
                    <Button Grid.Column="1"
                            Content="Найти" 
                            Command="{Binding SearchCommand}"
                            Padding="15,5"
                            Margin="5,0,0,0"/>
                </Grid>

                <!-- Фильтр по категории -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                    <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding FilterCategory}"
                              Width="150"
                              Padding="5"/>
                </StackPanel>

                <!-- Кнопка очистки -->
                <Button Grid.Column="2"
                        Content="Сбросить фильтры" 
                        Command="{Binding ClearSearchCommand}"
                        Padding="15,5"
                        Margin="20,0,0,0"/>
                
                <!-- Статус -->
                <TextBlock Grid.Column="3"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"
                           FontStyle="Italic"
                           Foreground="#666"/>
            </Grid>
        </Border>

        <!-- Таблица лекарств -->
        <Border Grid.Row="2"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="5">
            <DataGrid ItemsSource="{Binding Medicines}"
                      SelectedItem="{Binding SelectedMedicine}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F5F5F5"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      BeginningEdit="DataGrid_BeginningEdit"
                      RowEditEnding="DataGrid_RowEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding MedicineName, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                    <DataGridTextColumn Header="Крит.норма" Binding="{Binding CriticalNorm, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    <DataGridTextColumn Header="Тек.запас" Binding="{Binding CurrentStock, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    <DataGridTextColumn Header="Себест." Binding="{Binding ManufacturingCost, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding SalePrice, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Рецепт" Binding="{Binding RequiresPrescription, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridCheckBoxColumn Header="Готовое" Binding="{Binding IsReadyMade, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Индикатор загрузки -->
        <Border Grid.Row="2"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,0,0,10"/>
                <TextBlock Text="Загрузка данных..." 
                           HorizontalAlignment="Center"
                           FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Информация о количестве -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="{Binding Medicines.Count, StringFormat='Всего лекарств: {0}'}"
                       FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</UserControl>
